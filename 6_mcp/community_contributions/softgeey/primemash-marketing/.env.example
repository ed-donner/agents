# ── AI ──────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

# ── LinkedIn OAuth 2.0 ───────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
# Run: uv run python scripts/get_linkedin_token.py  to generate these
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token
LINKEDIN_PERSON_URN=urn:li:person:YOUR_PERSON_ID

# ── X (Twitter) OAuth 1.0a ───────────────────────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret
TWITTER_BEARER_TOKEN=your_twitter_bearer_token

# ── Instagram ────────────────────────────────────────────────────────────────
# disabled = skip Instagram entirely (default until Make.com/Buffer is configured)
# Set to: make or buffer once you have credentials
INSTAGRAM_STRATEGY=disabled

# Strategy A — Buffer (sign up free at buffer.com, connect Instagram, get token)
BUFFER_ACCESS_TOKEN=your_buffer_access_token
BUFFER_INSTAGRAM_PROFILE_ID=your_buffer_instagram_profile_id

# Strategy B — Make.com webhook (create scenario: Webhook → Instagram for Business)
MAKE_INSTAGRAM_WEBHOOK_URL=https://hook.eu1.make.com/your_webhook_id

# ── API Server ───────────────────────────────────────────────────────────────
API_SECRET_KEY=change_this_to_a_long_random_secret_32chars
API_HOST=0.0.0.0
API_PORT=8000

# ── Next.js (copy to frontend/.env.local) ────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change_this_to_another_long_random_secret
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
