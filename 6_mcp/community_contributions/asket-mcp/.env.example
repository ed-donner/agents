# Where SQLite notes and state live (default: ./data). Use an absolute path in production.
ASKET_MCP_DATA_DIR=data

# Allow-listed Brain folder (Markdown study library). Use an absolute path in production.
PERSONAL_STUDY_BRAIN_DIR=PersonalStudyBrain

# Logging
ASKET_MCP_LOG_LEVEL=INFO

# Transport: stdio (desktop clients), sse or streamable-http (Docker / remote)
ASKET_MCP_TRANSPORT=stdio
ASKET_MCP_HOST=127.0.0.1
ASKET_MCP_PORT=8765

# ------------------------------------------------------------------------------
# Semantic memory (ChromaDB local + OpenAI embeddings & chat)
# Install: uv sync --extra semantic
# Embeddings and RAG send content to OpenAI — see privacy notes in README.
# ------------------------------------------------------------------------------
OPENAI_API_KEY=

# Optional: override Chroma persist dir (default: <ASKET_MCP_DATA_DIR>/chroma)
# ASKET_CHROMA_PATH=

# ASKET_EMBEDDING_MODEL=text-embedding-3-small
# ASKET_CHAT_MODEL=gpt-4o-mini
# ASKET_RAG_TOP_K=8
# ASKET_SEMANTIC_CHUNK_CHARS=1600
# ASKET_SEMANTIC_CHUNK_OVERLAP=200

# ------------------------------------------------------------------------------
# Streamlit UI (asket-mcp-ui) — uv run asket-mcp-ui
# ------------------------------------------------------------------------------
ASKET_UI_HOST=127.0.0.1
ASKET_UI_PORT=7860

# Reverse-proxy subpath (e.g. /study). Passed to Streamlit as --server.baseUrlPath when set.
ASKET_UI_ROOT_PATH=

# Legacy / unused with the current Streamlit launcher (kept for config compatibility; use proxy auth instead).
ASKET_UI_AUTH_USERNAME=
ASKET_UI_AUTH_PASSWORD=
ASKET_UI_AUTH_MESSAGE=

# TLS: prefer HTTPS at your reverse proxy. These are validated on startup; full TLS in exec is not wired—see README.
ASKET_UI_SSL_CERTFILE=
ASKET_UI_SSL_KEYFILE=
ASKET_UI_SSL_VERIFY=true

# Unused with Streamlit (Gradio-era); safe to leave default.
ASKET_UI_GRADIO_ANALYTICS=false
ASKET_UI_SSR_MODE=false
ASKET_UI_MAX_THREADS=16
ASKET_UI_STRICT_CORS=false

# Unused with Streamlit (Gradio-era share/debug flags).
ASKET_UI_DEBUG=false
ASKET_UI_SHARE=false
ASKET_UI_QUIET=true
ASKET_UI_MINIMAL_FOOTER=false

# If HTTP(S)_PROXY is set, the UI launcher merges 127.0.0.1, localhost, ::1 into NO_PROXY / no_proxy at startup.

# ------------------------------------------------------------------------------
# Optional: Pushover (send_push returns a hint if unset)
# ------------------------------------------------------------------------------
PUSHOVER_USER=
PUSHOVER_TOKEN=

# ------------------------------------------------------------------------------
# Fetch limits
# ------------------------------------------------------------------------------
ASKET_MCP_HTTP_TIMEOUT=30
ASKET_MCP_FETCH_MAX_BYTES=500000
