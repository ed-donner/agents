  {
   "cell_type": "code",
   "execution_count": null,
   "id": "integration-pattern",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Production pattern: tiered model routing\n",
    "# Use the cheap fine-tuned model for routing decisions;\n",
    "# use the full model only for the actual response generation.\n",
    "\n",
    "class AgentRouter:\n",
    "    \"\"\"\n",
    "    Routes user messages to the right handler using a fine-tuned classifier.\n",
    "    Only the routing decision uses the cheap model — the response uses the best model.\n",
    "    \"\"\"\n",
    "    def __init__(self, router_model: str, response_model: str):\n",
    "        self.router_model = router_model\n",
    "        self.response_model = response_model\n",
    "\n",
    "    def classify_intent(self, message: str) -> str:\n",
    "        r = client.chat.completions.create(\n",
    "            model=self.router_model,\n",
    "            messages=[\n",
    "                {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
    "                {\"role\": \"user\",   \"content\": message},\n",
    "            ],\n",
    "            temperature=0,\n",
    "        )\n",
    "        return r.choices[0].message.content.strip()\n",
    "\n",
    "    def handle(self, message: str) -> dict:\n",
    "        intent = self.classify_intent(message)\n",
    "\n",
    "        # Each handler could be a separate specialist agent in a real system\n",
    "        handler_prompts = {\n",
    "            \"book_flight\":     \"You are a helpful airline booking agent. Help the user book a flight.\",\n",
    "            \"cancel_booking\":  \"You are a helpful airline agent. Help the user cancel their booking.\",\n",
    "            \"check_status\":    \"You are a helpful airline agent. Help the user check their flight status.\",\n",
    "            \"request_refund\":  \"You are a helpful airline agent. Process the user's refund request.\",\n",
    "            \"general_inquiry\": \"You are a helpful airline agent. Answer the user's general question.\",\n",
    "        }\n",
    "\n",
    "        system = handler_prompts.get(intent, handler_prompts[\"general_inquiry\"])\n",
    "\n",
    "        r = client.chat.completions.create(\n",
    "            model=self.response_model,\n",
    "            messages=[\n",
    "                {\"role\": \"system\", \"content\": system},\n",
    "                {\"role\": \"user\",   \"content\": message},\n",
    "            ],\n",
    "        )\n",
    "\n",
    "        return {\n",
    "            \"intent\":   intent,\n",
    "            \"response\": r.choices[0].message.content,\n",
    "            \"routing_model\": self.router_model,\n",
    "            \"response_model\": self.response_model,\n",
    "        }\n",
    "\n",
    "# Use fine-tuned model for routing (cheap), gpt-4o-mini for response (good quality)\n",
    "router = AgentRouter(\n",
    "    router_model=fine_tuned_model,   # ~$0.0003/routing decision\n",
    "    response_model=\"gpt-4o-mini\",    # ~$0.002/response\n",
    ")\n",
    "\n",
    "test_msg = \"I need to fly from London to New York next Friday, business class.\"\n",
    "result = router.handle(test_msg)\n",
    "\n",
    "print(f\"Message:  {test_msg}\")\n",
    "print(f\"Intent:   {result['intent']} (classified by {result['routing_model'][:30]}...)\")\n",
    "print(f\"Response ({result['response_model']}):\")\n",
    "print(result['response'])"
   ]
