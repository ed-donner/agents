OPENAI_API_KEY=sk-...
# Optional: Google search via Serper (otherwise search_web uses free DuckDuckGo, no key)
# SERPER_API_KEY=...
# Optional: Pushover mobile/desktop notifications (https://pushover.net/)
# PUSHOVER_TOKEN=your_application_token
# PUSHOVER_USER=your_user_key
# Optional: set to 1 to skip Playwright (faster startup, no browser tools)
# JOB_HUNT_DISABLE_BROWSER=1
# Optional: show browser window when Playwright is enabled
# JOB_HUNT_HEADFUL=1
